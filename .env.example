HERMES_DESKTOP_REMOTE_URL=http://your-hermes-backend:9119
HERMES_DESKTOP_REMOTE_TOKEN=your-session-token-here

# Set to true to disable KasmVNC basic auth (only when secured by Tailscale)
DISABLE_AUTH=false

# User/group IDs for file permissions (Unraid defaults: 99/100)
#PUID=1000
#PGID=1000

# Timezone
#TZ=Etc/UTC
